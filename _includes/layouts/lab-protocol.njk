<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="{{ description or 'BlastoDB - The open hub for Blastocystis research' }}">
  <title>{{ title }}</title>
  <link rel="stylesheet" href="{{ '/assets/style.css' | url }}">
  <link rel="stylesheet" href="{{ '/assets/collector.css' | url }}">
  <script>
    // Inject collector data into global scope for main.js to access
    window.collectorData = {{ collectorData | dump | safe }};
  </script>
  <script src="{{ '/assets/main.js' | url }}" defer></script>
</head>
<body>
  {% include "layouts/header.njk" %}

  <main>
    <div class="hero hero-content-center">
        <h-hero>{{ title }}</h-hero>
    </div>
    {{ content | processSpans | safe }}

    {% if related_publications and related_publications.length %}
    <hr>
    <h1>References</h1>
    <div class="collector"
        data-collection="publications"
        data-path="publications"
        data-opts='{"arrange":"rows","display_items":"all","search_fields":[],"prefilter":{"orGroups":[{% for key in related_publications %}[{"field":"key","value":{{ key | dump | safe }}}]{% if not loop.last %},{% endif %}{% endfor %}]},"card_template":"references","clickable":false}'>
    </div>
    {% endif %}

    <hr>
    <div style="text-align:center">
      <a href="{{ '/lab-protocols/' | url }}" class="btn">← Back to Lab Protocols</a>
    </div>
  </main>

  {% include "layouts/footer.njk" %}
</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
  <link rel="icon" href={{ collections.branding.favicon }} sizes="any">
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="{{ description or title }}">
  <title>{{collections.branding.site_title}} - {{ title }}</title>
  <link rel="stylesheet" href="{{ '/assets/style.css' | url }}">
  <link rel="stylesheet" href="{{ '/assets/collector.css' | url }}">
  <script>
    // Inject data into global scope for main.js to access
    window.collectorData = {{ collectorData | dump | safe }};
  </script>
  <script src="{{ '/assets/main.js' | url }}" defer></script>
</head>
<body>
  {% include "layouts/header.njk" %}
  <main>

    {% set lab = affiliated_lab | labByKey %}
    {% set entryCountry = country or (lab.country if lab) %}

    <div class="hero hero-content-center">
      <h-hero>{{ title }}</h-hero>

      <div class="biobank-chips">
        {% if tags %}{% for t in tags %}<span class="tag">{{ t }}</span>{% endfor %}{% endif %}
        {% if entryCountry %}<span class="tag tag-muted">{{ entryCountry }}</span>{% endif %}
      </div>

      <a class="btn biobank-request-btn" href="mailto:{{ contact_person_email }}?subject=Biobank request: {{ title }}">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
        Request via email
      </a>

      <p class="tip">
       Ordering is via request by email. Price and availability may varie, {{ contact_person_name or "the contact person" }} will get back to you as soon as possible with availability, shipping times and payment information.
      </p>
    </div>

    {{ content | processSpans | safe }}

      {% if picture %}
      <img class="biobank-image" src="{{ picture }}" alt="{{ title }}" />
      {% endif %}
      
    <hr>
    <section class="biobank-affiliation">
      <h2>Contact Information</h2>
      <table class="dataset-table">
        {% if contact_person_name %}<tr><th>Contact person</th><td>{{ contact_person_name }}</td></tr>{% endif %}
        {% if contact_person_email %}<tr><th>Email</th><td><a href="mailto:{{ contact_person_email }}?subject=Biobank request: {{ title }}">{{ contact_person_email }}</a></td></tr>{% endif %}
        {% if lab and lab.lab_name %}<tr><th>Research lab</th><td>{{ lab.lab_name }}</td></tr>{% endif %}
        {% if lab and lab.institution_name %}<tr><th>Institution</th><td>{{ lab.institution_name }}</td></tr>{% endif %}
        {% if entryCountry %}<tr><th>Country</th><td>{{ entryCountry }}</td></tr>{% endif %}
        {% if lab and lab.contact_url %}<tr><th>Lab webpage</th><td><a href="{{ lab.contact_url }}" target="_blank" rel="noopener">{{ lab.contact_url }}</a></td></tr>{% endif %}
      </table>
    </section>

    <hr>
    <div style="text-align:center">
      <a href="{{ '/biobank/' | url }}" class="btn">← Back to Biobank</a>
    </div>
  </main>

  {% include "layouts/footer.njk" %}
</body>
</html>

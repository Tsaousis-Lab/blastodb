<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="{{ description or 'BlastoDB - The open hub for Blastocystis research' }}">
  <title>{{ title }}</title>
  <link rel="stylesheet" href="{{ '/assets/style.css' | url }}">
  <script>
    // Inject news data into global scope for main.js to access
    window.news = {{ news | dump | safe }};
  </script>
  <script src="{{ '/assets/main.js' | url }}" defer></script>
</head>
<body>
  {% include "layouts/header.njk" %}

  <main>
    {{ content | safe }}

    <div class="protocol-footer">
      <a href="{{ '/lab-protocols/' | url }}" class="btn btn-secondary">← Back to Homepage</a>
    </div>
  </main>

  {% include "layouts/footer.njk" %}
</body>
</html>

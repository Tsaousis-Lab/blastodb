<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="{{ description or 'BlastoDB - The open hub for Blastocystis research' }}">
  <title>{{ title }}</title>
  <link rel="stylesheet" href="/assets/style.css">
  <script src="/assets/main.js" defer></script>
</head>
<body>
  <header>
    <div class="header-inner">
      <a href="/" class="site-logo">BlastoDB</a>
      <nav>
        {% set currentFileName = page.filePathStem | replace('/index', '') %}
        {% set navItems = collections.nav.items %}
        {% for item in navItems %}
          {% set itemPath = '/' + item.file.replace('content/', '').replace('.md', '') %}
          <a href="{{ item.url }}" {% if itemPath == currentFileName %}class="active"{% endif %}>
            {{ item.label }}
          </a>
        {% endfor %}
      </nav>
      <button class="nav-toggle" aria-label="Toggle navigation">☰</button>
    </div>
  </header>

  <main>
    {{ content | safe }}
  </main>

  <footer>
    <p>&copy; 2024 BlastoDB. Built with <a href="https://www.11ty.dev/">Eleventy</a>.</p>
  </footer>
</body>
</html>

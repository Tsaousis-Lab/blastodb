<header>
  <div class="header-inner">
    <a href="{{ '/' | url }}" class="site-logo">
      <img src="{{ (collections.branding.site_logo_upload or collections.branding.site_logo_url) | url }}" alt="BlastoDB logo" class="logo-image">
      <span>{{ collections.branding.site_title }}</span>
    </a>
    <nav>
      {% for item in collections.docs_header.items %}
        <a href="{{ item.url | url }}">{{ item.label }}</a>
      {% endfor %}
    </nav>
    <button class="nav-toggle" aria-label="Toggle navigation">☰</button>
  </div>
</header>

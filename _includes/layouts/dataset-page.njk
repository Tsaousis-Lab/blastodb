<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="{{ description or 'BlastoDB - The open hub for Blastocystis research' }}">
  <title>{{ title }}</title>
  <link rel="stylesheet" href="{{ '/assets/style.css' | url }}">
  <script>
    // Inject data into global scope for main.js to access
    window.collectorData = {{ collectorData | dump | safe }};
  </script>
  <script src="{{ '/assets/main.js' | url }}" defer></script>
</head>
<body>
  {% include "layouts/header.njk" %}

  <main>
    <div class="hero" style="text-align: center; display: flex; flex-direction: column; align-items: center;">
      <h1>{{ title }}</h1>

      {% if subtypes and subtypes.length %}
        <div class="collector-item-tags" style="justify-content: center; margin: rem 0;">
          {% for subtype in subtypes %}
            <span class="tag">{{ subtype }}</span>
          {% endfor %}
        </div>
      {% endif %}

    {% if strains and strains.length %}
        <div class="collector-item-tags" style="justify-content: center; margin: rem 0;">
          {% for strain in strains %}
            <span class="tag">{{ strain }}</span>
          {% endfor %}
        </div>
    {% endif %}

    {% if datatypes and datatypes.length %}
        <div class="collector-item-tags" style="justify-content: center; margin: rem 0;">
          {% for datatype in datatypes %}
            <span class="tag">{{ datatype }}</span>
          {% endfor %}
        </div>
    {% endif %}

    {% if detection_methods and detection_methods.length %}
        <div class="collector-item-tags" style="justify-content: center; margin: rem 0;">
          {% for detection_method in detection_methods %}
            <span class="tag">{{ detection_method }}</span>
          {% endfor %}
        </div>
    {% endif %}

    {% if sources and sources.length %}
        <div class="collector-item-tags" style="justify-content: center; margin: rem 0;">
          {% for source in sources %}
            <span class="tag">{{ source }}</span>
          {% endfor %}
        </div>
    {% endif %}

    {% if data_origins and data_origins.length %}
        <div class="collector-item-tags" style="justify-content: center; margin: rem 0;">
          {% for data_origin in data_origins %}
            <span class="tag">{{ data_origin }}</span>
          {% endfor %}
        </div>
    {% endif %}

    {% if countries and countries.length %}
        <div class="collector-item-tags" style="justify-content: center; margin: rem 0;">
          {% for countrie in countries %}
            <span class="tag">{{ countrie }}</span>
          {% endfor %}
        </div>
    {% endif %}

    {% if data_sources and data_sources.length %}
        <div class="collector-item-tags" style="justify-content: center; margin: rem 0;">
          {% for data_source in data_sources %}
            <span class="tag">{{ data_source }}</span>
          {% endfor %}
        </div>
    {% endif %}

        <button class="btn" onclick="window.open('{{ link_to_source }}', '_blank')">Open Dataset</button>
    </div>


    {{ content | processSpans | safe }}

    <div class="protocol-footer" style="text-align:center">
      <a href="{{ '/datasets/' | url }}" class="btn btn-secondary">← Back to Datasets</a>
    </div>
  </main>

  {% include "layouts/footer.njk" %}
</body>
</html>

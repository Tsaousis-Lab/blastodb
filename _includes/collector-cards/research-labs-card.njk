<div class="collector-card collector-card-lab">

  {% set institution_logo = institution_logo_upload or institution_logo_url %}
  {% if institution_logo %}
  <div class="lab-card-image">
    <img src="{{ institution_logo }}" alt="{{ lab_name }}" loading="lazy" />
  </div>
  {% endif %}

  <div class="lab-card-body">
    <h3 class="card-title lab-card-name">{{ lab_name }}</h3>

    {% if short_description %}
    <p class="lab-card-description">{{ short_description }}</p>
    {% endif %}

    {% if contact_name %}
    <div class="lab-card-contact">
      {% if contact_img_path %}
      <img class="lab-card-avatar" src="{{ contact_img_path }}" alt="{{ contact_name }}" loading="lazy" />
      {% else %}
      <div class="lab-card-avatar lab-card-avatar-placeholder">{{ contact_name | truncate(1, true, '') }}</div>
      {% endif %}
      <div class="lab-card-contact-info">
        <span class="lab-card-contact-name">{{ contact_name }}</span>
        {% if contact_mail %}
        <a class="lab-card-contact-email" href="mailto:{{ contact_mail }}">
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          {{ contact_mail }}
        </a>
        {% endif %}
        {% if contact_url %}
        <a class="lab-card-contact-email" href="{{ contact_url }}" target="_blank" rel="noopener">
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          Webpage
        </a>
        {% endif %}
      </div>
    </div>
    {% endif %}

    {% if institution_name or institution_address %}
    <div class="lab-card-institution">
      <div class="lab-card-address">
        {% if institution_name %}<strong>{{ institution_name }}</strong>{% endif %}
        {% if institution_address %}{{ institution_address }}{% endif %}
      </div>
    </div>
    {% endif %}
  </div>

</div>

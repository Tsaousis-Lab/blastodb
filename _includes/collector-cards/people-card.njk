<div class="collector-card collector-card-person">
  {% if picture %}
  <img class="person-card-avatar" src="{{ picture }}" alt="{{ name }}" loading="lazy" />
  {% endif %}

  <div class="person-card-body">
    <h3 class="card-title person-card-name">{{ name }}</h3>
    {% if role %}
    <span class="tag person-card-role">{{ role }}</span>
    {% endif %}
    {% if affiliation %}
    <p class="person-card-affiliation">{{ affiliation }}</p>
    {% endif %}
    {% if mail or website or github %}
    <div class="person-card-links">
      {% if mail %}
      <a class="person-card-link" href="mailto:{{ mail }}">
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
        {{ mail }}
      </a>
      {% endif %}
      {% if website %}
      <a class="person-card-link" href="{{ website }}" target="_blank" rel="noopener">
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
        Webpage
      </a>
      {% endif %}
      {% if github %}
      <a class="person-card-link" href="{{ github }}" target="_blank" rel="noopener">
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .5C5.73.5.5 5.73.5 12c0 5.08 3.29 9.39 7.86 10.91.57.1.78-.25.78-.55 0-.27-.01-1.13-.02-2.04-3.2.7-3.88-1.36-3.88-1.36-.52-1.34-1.28-1.7-1.28-1.7-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.03 1.75 2.69 1.25 3.34.96.1-.74.39-1.25.71-1.54-2.56-.29-5.25-1.28-5.25-5.7 0-1.26.45-2.29 1.18-3.1-.12-.29-.51-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.79 0c2.21-1.49 3.18-1.18 3.18-1.18.62 1.59.23 2.76.11 3.05.74.81 1.18 1.84 1.18 3.1 0 4.43-2.7 5.41-5.27 5.69.41.36.78 1.06.78 2.14 0 1.55-.01 2.79-.01 3.17 0 .3.21.66.79.55A11.5 11.5 0 0 0 23.5 12C23.5 5.73 18.27.5 12 .5Z"/></svg>
        GitHub
      </a>
      {% endif %}
    </div>
    {% endif %}
  </div>
</div>

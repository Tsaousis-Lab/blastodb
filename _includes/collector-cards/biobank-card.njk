<div class="collector-card collector-card-biobank">

  {% if picture %}
  <div class="lab-card-image">
    <img src="{{ picture }}" alt="{{ title }}" loading="lazy" />
  </div>
  {% endif %}

  <div class="lab-card-body">
    <h3 class="card-title">{{ title }}</h3>

    {% if resource_type or country %}
    <div class="dataset-chips">
      {% if resource_type %}<span class="tag">{{ resource_type }}</span>{% endif %}
      {% if country %}<span class="tag tag-muted">{{ country }}</span>{% endif %}
    </div>
    {% endif %}

    {% if excerpt %}
    <p class="lab-card-description">{{ excerpt }}</p>
    {% endif %}

    {% if contact_person_name %}
    <div class="lab-card-contact">
      <div class="lab-card-contact-info">
        <span class="lab-card-contact-name">{{ contact_person_name }}</span>
        {% if contact_person_email %}
        <a class="lab-card-contact-email" href="mailto:{{ contact_person_email }}?subject=Biobank request: {{ title }}" onclick="event.stopPropagation()">
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          Request via email
        </a>
        {% endif %}
      </div>
    </div>
    {% endif %}
  </div>

</div>

<div class="collector-card collector-card-publication">
  <h3 class="collector-card-title">
    {% if pageUrl %}<a href="{{ pageUrl }}">{{ title }}</a>{% else %}{{ title }}{% endif %}
  </h3>

  {% if formattedDate %}
    <div class="collector-card-date">{{ formattedDate }}</div>
  {% endif %}

  {% if authors and authors.length %}
    <div class="collector-card-authors">
      {{ authors | join(", ") }}
    </div>
  {% endif %}

  {% if journal %}
    <div class="collector-card-journal">{{ journal }}</div>
  {% endif %}

  {% if url or doi %}
    <div class="collector-card-links">
      {% if url %}
        <a href="{{ url }}" target="_blank" rel="noopener">Publication Link</a>
      {% endif %}
      {% if doi %}
        <a href="https://doi.org/{{ doi }}" target="_blank" rel="noopener">DOI: {{ doi }}</a>
      {% endif %}
    </div>
  {% endif %}
</div>
